HEADROOM_HOST=0.0.0.0
HEADROOM_TELEMETRY=off

# No API keys needed: with Claude Pro / ChatGPT Plus, the auth comes from
# Claude Code CLI / Codex CLI's own subscription login (OAuth) and is
# forwarded through the proxy automatically.

# If proxying to a custom OpenAI-compatible endpoint, uncomment:
# OPENAI_TARGET_API_URL=https://api.x.ai
