HEADROOM_HOST=0.0.0.0
HEADROOM_TELEMETRY=off

# Used by the headroom-cli service to read your Claude/Codex/Gemini CLI auth
# (OAuth) configs. Defaults to your $HOME; override only if it differs
# (e.g. running from a different user/machine):
# HEADROOM_HOST_HOME=/Users/you

# Host directory to mount as the cli's /workspace (defaults to current dir):
# HEADROOM_WORKSPACE=.

# No API keys needed: with Claude Pro / ChatGPT Plus, the auth comes from
# Claude Code CLI / Codex CLI's own subscription login (OAuth) and is
# forwarded through the proxy automatically.

# If proxying to a custom OpenAI-compatible endpoint, uncomment:
# OPENAI_TARGET_API_URL=https://api.x.ai

# If proxying Anthropic traffic to a custom endpoint, uncomment:
# ANTHROPIC_TARGET_API_URL=https://litellm.company.internal

# Daily spend cap in USD (no limit by default):
# HEADROOM_BUDGET=10

# token = max compression (default), cache = freeze prior turns:
# HEADROOM_MODE=token
